{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "turnip_text",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_group"
      }
    },
    "_group": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "escaped"
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        },
        {
          "type": "SYMBOL",
          "name": "raw_scope"
        },
        {
          "type": "SYMBOL",
          "name": "eval_bracket"
        },
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "dash"
        },
        {
          "type": "SYMBOL",
          "name": "scope"
        },
        {
          "type": "SYMBOL",
          "name": "_anything_else"
        }
      ]
    },
    "raw_scope": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "raw_scope_open"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "raw_scope_internal"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "raw_scope_close"
        }
      ]
    },
    "raw_scope_open": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "###\\{"
        },
        {
          "type": "PATTERN",
          "value": "##\\{"
        },
        {
          "type": "PATTERN",
          "value": "#\\{"
        }
      ]
    },
    "raw_scope_close": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\}\\#\\#\\#"
        },
        {
          "type": "PATTERN",
          "value": "\\}\\#\\#"
        },
        {
          "type": "PATTERN",
          "value": "\\}\\#"
        }
      ]
    },
    "raw_scope_internal": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "escaped"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "eval_bracket_open"
          },
          {
            "type": "SYMBOL",
            "name": "eval_bracket_close"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "dash"
          },
          {
            "type": "SYMBOL",
            "name": "scope"
          },
          {
            "type": "SYMBOL",
            "name": "_anything_else"
          }
        ]
      }
    },
    "eval_bracket": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "eval_bracket_open"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "eval_bracket_internal"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "eval_bracket_close"
        }
      ]
    },
    "eval_bracket_open": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\[---"
        },
        {
          "type": "PATTERN",
          "value": "\\[--"
        },
        {
          "type": "PATTERN",
          "value": "\\[-"
        },
        {
          "type": "PATTERN",
          "value": "\\["
        }
      ]
    },
    "eval_bracket_close": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "---\\]"
        },
        {
          "type": "PATTERN",
          "value": "--\\]"
        },
        {
          "type": "PATTERN",
          "value": "-\\]"
        },
        {
          "type": "PATTERN",
          "value": "\\]"
        }
      ]
    },
    "eval_bracket_internal": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "escaped"
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          },
          {
            "type": "SYMBOL",
            "name": "raw_scope_open"
          },
          {
            "type": "SYMBOL",
            "name": "raw_scope_close"
          },
          {
            "type": "SYMBOL",
            "name": "comment"
          },
          {
            "type": "SYMBOL",
            "name": "dash"
          },
          {
            "type": "SYMBOL",
            "name": "scope"
          },
          {
            "type": "SYMBOL",
            "name": "_anything_else"
          }
        ]
      }
    },
    "scope": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_group"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "comment": {
      "type": "PREC",
      "value": -1,
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[^\\{\\r\\n][^\\r\\n]*"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "_newline"
          }
        ]
      }
    },
    "escaped": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\\"
          },
          {
            "type": "PATTERN",
            "value": "."
          }
        ]
      }
    },
    "_newline": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "\\r\\n"
        },
        {
          "type": "PATTERN",
          "value": "\\r"
        },
        {
          "type": "PATTERN",
          "value": "\\n"
        }
      ]
    },
    "dash": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": "-"
        },
        {
          "type": "PATTERN",
          "value": "--"
        },
        {
          "type": "PATTERN",
          "value": "---"
        }
      ]
    },
    "_anything_else": {
      "type": "PATTERN",
      "value": "[^\\r\\n\\\\\\#\\[\\]\\{\\}\\-]+"
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}